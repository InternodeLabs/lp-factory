---
import ContentLayout from "@/layouts/ContentLayout.astro";
import { AskYourAI } from "@/components/content/AskYourAI";
import {
  getAllContentEntries,
  getContentByType,
  getFeaturedContent,
  getAllContentTags,
  getContentTypeLabel,
  contentUrl,
  entrySlug,
} from "@/lib/content";
import {
  CONTENT_SITE_URL,
  MAIN_SITE_URL,
  SITE_DESCRIPTION,
  SITE_TITLE,
  absoluteUrl,
  formatDisplayDate,
} from "@/lib/site";
import {
  buildWebSiteSchema,
  buildOrganizationSchema,
  buildWebPageSchema,
  wrapGraph,
} from "@/lib/seo";

const allContent = await getAllContentEntries();
const featuredContent = await getFeaturedContent(3);
const answers = await getContentByType("answer");
const useCases = await getContentByType("use-case");
const updates = await getContentByType("update");
const tags = await getAllContentTags();

const jsonLd = wrapGraph(
  buildWebSiteSchema(),
  buildOrganizationSchema(),
  buildWebPageSchema({
    url: CONTENT_SITE_URL,
    name: SITE_TITLE,
    description: SITE_DESCRIPTION,
  }),
  {
    "@type": "ItemList",
    "@id": absoluteUrl("/#content-index"),
    itemListElement: allContent.map((entry, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: absoluteUrl(contentUrl(entrySlug(entry))),
      name: entry.data.title,
    })),
  },
);
---

<ContentLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  canonical={CONTENT_SITE_URL}
  jsonLd={jsonLd}
>
  <main id="main-content" class="mx-auto max-w-4xl px-4 py-12 md:py-16">
    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-zinc-500">
      <span aria-current="page">Home</span>
    </nav>

    <section class="max-w-3xl space-y-5">
      <h1 class="text-3xl font-semibold tracking-tight text-zinc-950 md:text-4xl">
        Answers, use cases, and updates about organizational memory for teams
        and AI agents.
      </h1>
      <p class="text-lg leading-8 text-zinc-700">
        This site publishes plain-language content so people, search engines,
        and AI systems can reach the content efficiently to understand how
        to build organizational memory with Internode.
      </p>
    </section>

    <AskYourAI client:visible />

    <section class="mt-10 max-w-3xl space-y-5">
      <p class="leading-8 text-zinc-700">
        Start with the fundamentals, move into the workflow examples, or visit
        <a href={MAIN_SITE_URL} target="_blank" rel="noopener noreferrer" class="font-semibold text-zinc-950 hover:underline">internode.ai</a>
        for the main product site and try it out for free.
      </p>
      <details class="text-sm text-zinc-500">
        <summary class="cursor-pointer select-none hover:text-zinc-700">
          Topics covered
        </summary>
        <p class="mt-1">{tags.join(", ")}.</p>
      </details>
    </section>

    {featuredContent.length > 0 && (
      <section class="mt-14 border-t border-zinc-200 pt-10">
        <h2 class="text-xl font-semibold text-zinc-950">Featured</h2>
        <ul class="mt-6 space-y-6">
          {featuredContent.map((entry) => (
            <li class="space-y-1">
              <a href={contentUrl(entrySlug(entry))} class="font-semibold text-zinc-950 hover:underline">{entry.data.title}</a>
              <p class="text-sm text-zinc-600">
                {getContentTypeLabel(entry.data.type)} &middot; <time datetime={entry.data.publishedAt}>{formatDisplayDate(entry.data.publishedAt)}</time>
              </p>
              <p class="text-zinc-800">{entry.data.excerpt}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="mt-14 border-t border-zinc-200 pt-10" id="answers">
      <h2 class="text-xl font-semibold text-zinc-950">Answers</h2>
      <ul class="mt-6 space-y-6">
        {answers.map((entry) => (
          <li class="space-y-1">
            <a href={contentUrl(entrySlug(entry))} class="font-semibold text-zinc-950 hover:underline">{entry.data.title}</a>
              <p class="text-sm text-zinc-600">
                {getContentTypeLabel(entry.data.type)} &middot; <time datetime={entry.data.publishedAt}>{formatDisplayDate(entry.data.publishedAt)}</time>
              </p>
              <p class="text-zinc-800">{entry.data.excerpt}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-14 border-t border-zinc-200 pt-10" id="use-cases">
      <h2 class="text-xl font-semibold text-zinc-950">Use cases</h2>
      <ul class="mt-6 space-y-6">
        {useCases.map((entry) => (
          <li class="space-y-1">
            <a href={contentUrl(entrySlug(entry))} class="font-semibold text-zinc-950 hover:underline">{entry.data.title}</a>
            <p class="text-sm text-zinc-600">
              {getContentTypeLabel(entry.data.type)} &middot; <time datetime={entry.data.publishedAt}>{formatDisplayDate(entry.data.publishedAt)}</time>
            </p>
            <p class="text-zinc-800">{entry.data.excerpt}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-14 border-t border-zinc-200 pt-10" id="updates">
      <h2 class="text-xl font-semibold text-zinc-950">Updates</h2>
      <ul class="mt-6 space-y-6">
        {updates.map((entry) => (
          <li class="space-y-1">
            <a href={contentUrl(entrySlug(entry))} class="font-semibold text-zinc-950 hover:underline">{entry.data.title}</a>
            <p class="text-sm text-zinc-600">
              {getContentTypeLabel(entry.data.type)} &middot; <time datetime={entry.data.publishedAt}>{formatDisplayDate(entry.data.publishedAt)}</time>
            </p>
            <p class="text-zinc-800">{entry.data.excerpt}</p>
          </li>
        ))}
      </ul>
    </section>
  </main>
</ContentLayout>
