---
import { cn } from "@/lib/utils";
import { ClickToPlayVideo } from "./ClickToPlayVideo";
import { TrackClick } from "@/components/tracking/TrackClick";
import type { CampaignConfig, SectionConfig } from "@/config/types";
import { ctaClassName } from "./lp-cta-classes";

type HeroSection = Extract<SectionConfig, { type: "hero" }>;

interface Props {
  section: HeroSection;
  config: CampaignConfig;
  campaign: string;
}

const { section, config, campaign } = Astro.props;
const { theme, cta, tracking } = config;
---

<section
  class={cn(
    "relative flex min-h-screen flex-col overflow-hidden",
    theme.darkMode && "dark",
  )}
>
  {section.backgroundImage ? (
    <>
      <img
        src={section.backgroundImage}
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div
        class="absolute inset-0 bg-gradient-to-b from-gray-950/85 via-gray-950/75 to-gray-950/90 dark:from-gray-950/90 dark:via-gray-950/80 dark:to-gray-950/95"
        aria-hidden="true"
      />
    </>
  ) : (
    <div
      class="absolute inset-0 bg-gradient-to-b from-transparent via-gray-50/30 to-gray-100/50 dark:from-transparent dark:via-gray-900/20 dark:to-gray-950/40"
      aria-hidden="true"
    />
  )}

  <div class="relative z-10 flex flex-1 flex-col pt-[40px] pb-16 px-4 md:pb-24 md:px-8">
    <div class="mx-auto w-full max-w-5xl">
      <span class="inline-flex items-center gap-2.5 text-white" aria-label="Internode">
        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M0.572949 1.23664C0 2.02524 0 3.15016 0 5.4V14.6C0 16.8498 0 17.9748 0.572949 18.7634C0.757988 19.018 0.98196 19.242 1.23664 19.4271C2.02524 20 3.15016 20 5.4 20H14.6C16.8498 20 17.9748 20 18.7634 19.4271C19.018 19.242 19.242 19.018 19.4271 18.7634C20 17.9748 20 16.8498 20 14.6V5.4C20 3.15016 20 2.02524 19.4271 1.23664C19.242 0.98196 19.018 0.757988 18.7634 0.572949C17.9748 0 16.8498 0 14.6 0H5.4C3.15016 0 2.02524 0 1.23664 0.572949C0.98196 0.757988 0.757988 0.98196 0.572949 1.23664ZM10.2952 2.14875C10 2.52319 10 3.07171 10 4.16875V6.26751C10 6.74427 9.81668 7.20278 9.48798 7.54812C9.13737 7.91649 8.65106 8.125 8.1425 8.125H4.16875C3.07171 8.125 2.52319 8.125 2.14875 8.42019C2.06384 8.48712 1.98712 8.56384 1.92019 8.64875C1.625 9.02319 1.625 9.57171 1.625 10.6687V15.8313C1.625 16.9283 1.625 17.4768 1.92019 17.8513C1.98712 17.9362 2.06384 18.0129 2.14875 18.0798C2.52319 18.375 3.07171 18.375 4.16875 18.375H9.33125C10.4283 18.375 10.9768 18.375 11.3513 18.0798C11.4362 18.0129 11.5129 17.9362 11.5798 17.8513C11.875 17.4768 11.875 16.9283 11.875 15.8313V11.7021C11.875 11.2652 12.043 10.8451 12.3442 10.5286C12.6655 10.1911 13.1111 10 13.5771 10H15.8313C16.9283 10 17.4768 10 17.8513 9.70481C17.9362 9.63788 18.0129 9.56116 18.0798 9.47625C18.375 9.10181 18.375 8.55329 18.375 7.45625V4.16875C18.375 3.07171 18.375 2.52319 18.0798 2.14875C18.0129 2.06384 17.9362 1.98712 17.8513 1.92019C17.4768 1.625 16.9283 1.625 15.8313 1.625H12.5437C11.4467 1.625 10.8982 1.625 10.5237 1.92019C10.4388 1.98712 10.3621 2.06384 10.2952 2.14875Z" fill="#ffffff" />
        </svg>
        <span class="text-lg font-semibold tracking-wide">Internode</span>
      </span>
    </div>

    <div class="mx-auto flex w-full max-w-5xl flex-1 flex-col justify-center text-center">
      {section.kicker && (
        <p class="mx-auto inline-flex items-center gap-2 rounded-full border border-[var(--lp-primary)]/30 bg-[var(--lp-primary)]/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wide text-[var(--lp-primary)] md:text-sm">
          {section.kicker}
        </p>
      )}
      <h1
        class={cn(
          "text-balance bg-gradient-to-br from-[var(--lp-primary)] via-[var(--lp-primary)] to-[var(--lp-accent)] bg-clip-text py-[30px] text-4xl font-bold tracking-tight text-transparent md:text-5xl lg:text-6xl",
          section.backgroundImage && "drop-shadow-sm",
        )}
      >
        {section.headline}
      </h1>
      <p class={cn("mx-auto mt-6 max-w-3xl text-pretty text-lg md:mt-8 md:text-xl", "text-gray-600 dark:text-gray-300")}>
        {section.subheadline}
        {section.subheadlineEmphasis && (
          <>
            <br />
            <em class="mt-3 block text-gray-500 dark:text-gray-400">
              {section.subheadlineEmphasis}
            </em>
          </>
        )}
      </p>
      <div class="mt-10 md:mt-12">
        <TrackClick
          client:load
          campaign={campaign}
          campaignId={tracking.campaignId}
          section="hero"
          ctaText={section.ctaText}
          element="hero_primary_cta"
          captureExtras={{
            traffic_source: tracking.source,
            conversion_event: tracking.conversionEvent,
            href: cta.href,
          }}
        >
          <a
            href={cta.href}
            class={ctaClassName(cta.style, theme.darkMode)}
            rel="noopener"
          >
            {section.ctaText}
          </a>
        </TrackClick>
        {section.ctaSubtext && (
          <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">
            {section.ctaSubtext}
          </p>
        )}
      </div>

      {section.heroImage && (
        <figure class="mx-auto mt-12 w-full max-w-4xl md:mt-16">
          <div class="relative overflow-hidden rounded-xl border border-gray-200/20 shadow-2xl shadow-[var(--lp-primary)]/10 ring-1 ring-white/10 md:rounded-2xl">
            {section.heroVideo ? (
              <ClickToPlayVideo
                client:visible
                posterSrc={section.heroImage}
                videoId={section.heroVideo}
                alt={`${config.meta.title} - product demonstration`}
              />
            ) : (
              <img
                src={section.heroImage}
                alt={`${config.meta.title} - product screenshot`}
                width="2048"
                height="1456"
                loading="eager"
                fetchpriority="high"
                class="w-full"
              />
            )}
          </div>
          <figcaption class="sr-only">Internode product interface</figcaption>
        </figure>
      )}
    </div>
  </div>
</section>
