---
import { cn } from "@/lib/utils";
import type { SectionConfig } from "@/config/types";

type FaqSection = Extract<SectionConfig, { type: "faq" }>;

interface Props {
  section: FaqSection;
  darkMode: boolean;
}

const { section, darkMode } = Astro.props;
---

<section class={cn("py-16 px-4 md:py-24 md:px-8", darkMode && "dark")}>
  <div class="mx-auto max-w-5xl">
    <h2 class="text-center text-4xl font-bold tracking-tight text-gray-900 dark:text-white md:text-5xl lg:text-6xl">
      {section.title}
    </h2>
    <div class="mt-12 space-y-3 md:mt-16 md:space-y-4">
      {section.items.map((item, index) => (
        <details
          class={cn(
            "group overflow-hidden rounded-2xl border transition-shadow",
            "border-gray-200 bg-white shadow-sm dark:border-gray-800 dark:bg-gray-900/60",
            "open:shadow-md open:ring-1 open:ring-[var(--lp-primary)]/20 dark:open:shadow-lg",
          )}
          open={index === 0}
        >
          <summary
            class={cn(
              "flex w-full cursor-pointer items-center justify-between gap-4 px-5 py-5 text-left md:px-6 md:py-6",
              "text-lg font-semibold text-gray-900 transition-colors md:text-xl",
              "hover:bg-gray-50 dark:text-white dark:hover:bg-gray-800/80",
              "focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--lp-primary)] focus-visible:ring-offset-2 dark:focus-visible:ring-offset-gray-900",
              "list-none [&::-webkit-details-marker]:hidden",
            )}
          >
            <span class="text-pretty pr-2">{item.question}</span>
            <span
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[var(--lp-primary)]/30 text-[var(--lp-primary)] transition-colors duration-300 group-open:border-[var(--lp-accent)]/40 group-open:bg-[var(--lp-primary)]/10"
              aria-hidden="true"
            >
              <svg class="h-5 w-5 transition-transform duration-300 group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 5v14M5 12h14" />
              </svg>
            </span>
          </summary>
          <p class="border-t border-gray-200 px-5 pb-6 pt-2 text-lg leading-relaxed text-gray-600 dark:border-gray-800 dark:text-gray-300 md:px-6 md:pb-7 md:text-xl">
            {item.answer}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>
