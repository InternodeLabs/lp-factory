---
import { cn } from "@/lib/utils";
import { TrackClick } from "@/components/tracking/TrackClick";
import type { CampaignConfig, SectionConfig } from "@/config/types";
import { finalCtaButtonClassName } from "./lp-cta-classes";

type FinalCtaSection = Extract<SectionConfig, { type: "final-cta" }>;

interface Props {
  section: FinalCtaSection;
  config: CampaignConfig;
  campaign: string;
}

const { section, config, campaign } = Astro.props;
const { theme, cta, tracking } = config;
---

<section class={cn("py-16 px-4 md:py-24 md:px-8", theme.darkMode && "dark")}>
  <div class="mx-auto max-w-5xl">
    <div
      class={cn(
        "relative overflow-hidden rounded-3xl px-6 py-14 text-center shadow-2xl md:px-12 md:py-20",
        "bg-[var(--lp-primary)] text-white",
        "ring-1 ring-white/10",
      )}
    >
      <div class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-[var(--lp-accent)]/25 blur-3xl" aria-hidden="true" />
      <div class="pointer-events-none absolute -bottom-24 -left-16 h-72 w-72 rounded-full bg-white/10 blur-3xl" aria-hidden="true" />

      <div class="relative z-10 mx-auto max-w-3xl">
        <h2 class="text-balance text-4xl font-bold tracking-tight md:text-5xl lg:text-6xl">
          {section.headline}
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-pretty text-lg text-white/90 md:mt-8 md:text-xl">
          {section.subheadline}
        </p>
        <div class="mt-10 md:mt-12">
          <TrackClick
            client:load
            campaign={campaign}
            campaignId={tracking.campaignId}
            section="final-cta"
            ctaText={section.ctaText}
            element="final_cta_primary"
            captureExtras={{
              traffic_source: tracking.source,
              conversion_event: tracking.conversionEvent,
              href: cta.href,
            }}
          >
            <a
              href={cta.href}
              class={finalCtaButtonClassName(theme.darkMode)}
              rel="noopener"
            >
              {section.ctaText}
            </a>
          </TrackClick>
          {section.ctaSubtext && (
            <p class="mt-3 text-sm text-white/70">
              {section.ctaSubtext}
            </p>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
